{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "surecart/product-review-average-rating-stars",
  "title": "Star Rating",
  "description": "Display the product average rating stars.",
  "version": "1.0.0",
  "category": "surecart-product-page",
  "example": {},
  "usesContext": [
    "show_value",
    "link_to_reviews"
  ],
  "keywords": [
    "review",
    "average",
    "rating",
    "stars"
  ],
  "attributes": {
    "fill_color": {
      "type": "string",
      "default": ""
    },
    "size": {
      "type": "string",
      "default": "20px"
    },
    "link_to_reviews": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "interactivity": true,
    "color": {
      "text": false,
      "link": false,
      "background": false,
      "__experimentalDefaultControls": {
        "background": false,
        "text": false
      }
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": {
        "__experimentalDefault": "2px"
      },
      "__experimentalDefaultControls": {
        "padding": true,
        "margin": true,
        "blockGap": true
      }
    }
  },
  "textdomain": "surecart",
  "render": "file:./view.php",
  "style": "file:./style-index.css",
  "editorScript": "file:./index.js"
}