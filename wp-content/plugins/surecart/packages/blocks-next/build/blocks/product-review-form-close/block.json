{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "surecart/product-review-form-close",
  "title": "Review Form Close Button",
  "description": "Display the product review form close button.",
  "version": "1.0.0",
  "category": "surecart-product-page",
  "ancestor": [
    "surecart/product-review-form"
  ],
  "example": {},
  "supports": {
    "interactivity": true,
    "align": [
      "left",
      "center",
      "right"
    ],
    "color": {
      "gradients": true,
      "link": false,
      "__experimentalDefaultControls": {
        "background": true,
        "text": true
      }
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "__experimentalFontWeight": true
    },
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true,
      "__experimentalDefaultControls": {
        "color": true,
        "radius": true,
        "style": true,
        "width": true
      }
    }
  },
  "textdomain": "surecart",
  "render": "file:./view.php",
  "editorScript": "file:./index.js",
  "style": [
    "file:./style-index.css"
  ],
  "viewScriptModule": [
    "@surecart/product-review-form"
  ]
}